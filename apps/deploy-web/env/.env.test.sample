# Sample environment for Playwright e2e tests.
# Copy to env/.env.test.local and fill in secret values.

# Where the dev server is reachable. Default: http://localhost:3000
# BASE_URL=http://localhost:3000

# Akash chain network the tests run against. Default: sandbox
# NETWORK_ID=sandbox

# 12-word BIP39 mnemonic for the test wallet. Address must be funded on the
# selected NETWORK_ID (or the network's faucet must be reachable so that
# topUpWallet can refill it automatically).
TEST_WALLET_MNEMONIC=your twelve word mnemonic goes here ...

# Identifies test traffic via the user-agent. Any random string. Default:
# console-crypto-e2e
# E2E_TESTING_CLIENT_TOKEN=console-crypto-e2e
