############################################################
# Console Air ships with sensible defaults pointing at the
# Akash production Console infrastructure. The app boots and
# works with this file completely empty.
#
# Override any of the values below only if you operate your
# own Console API / chain RPC / provider proxy and want this
# instance to point at it instead of the hosted defaults.
############################################################

# Canonical public URL of this deployment. Used for SEO meta
# tags, outbound User-Agent strings, and the domain reference
# in Terms of Service / Privacy Policy.
# Default: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# Console HTTP API base URL per network. The /api/proxy/{network}/v1/* route
# forwards browser requests to the matching upstream so the UI talks only to
# its own origin. NEXT_PUBLIC_API_BASE_URL is the mainnet upstream; override
# the per-network vars only if you operate Console APIs that don't follow the
# console-api[-{network}].akash.network naming convention.
# Defaults: https://console-api[-{network}].akash.network
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_BASE_URL_SANDBOX=
NEXT_PUBLIC_API_BASE_URL_TESTNET=

# Akash stats / explorer URL (used for transaction and address links).
# Default: https://stats.akash.network
NEXT_PUBLIC_STATS_APP_URL=

# Provider proxy service URL used to reach Akash providers.
# %{NETWORK} is substituted with the active network id at runtime.
# Default: https://console.akash.network/provider-proxy-%{NETWORK}
NEXT_PUBLIC_PROVIDER_PROXY_URL=

# Akash chain REST API per network.
# Defaults: https://console.akash.network/api-{mainnet,testnet,sandbox}
NEXT_PUBLIC_BASE_API_MAINNET_URL=
NEXT_PUBLIC_BASE_API_TESTNET_URL=
NEXT_PUBLIC_BASE_API_SANDBOX_URL=

# URL of the SDL template catalog.
# Default: https://akash-templates.pages.dev
NEXT_PUBLIC_BASE_TEMPLATES_URL=

# "mainnet" | "sandbox" | "testnet" — default network the UI opens on.
# Default: mainnet
NEXT_PUBLIC_DEFAULT_NETWORK_ID=

# uakt amount used to pre-fill deposit fields.
# Default: 500000
NEXT_PUBLIC_DEFAULT_INITIAL_DEPOSIT=

# "true" redirects every route to /maintenance.
# Default: false
MAINTENANCE_MODE=

# Optional chain node URLs for mainnet (override default REST/RPC nodes).
DEFAULT_REST_API_NODE_URL_MAINNET=
DEFAULT_RPC_NODE_URL_MAINNET=

# Workaround for an upstream Next.js 14.2.35 packaging bug where its
# optionalDependencies pin @next/swc-* at 14.2.33 (mismatching next itself).
# Without this flag Next prints a noisy "Failed to patch lockfile" stack
# trace at startup; the app still runs either way. Safe to leave enabled.
NEXT_IGNORE_INCORRECT_LOCKFILE=1
